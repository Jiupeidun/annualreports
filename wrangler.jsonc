{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "annualreports",
  "main": "worker/index.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "run_worker_first": [
      "/*.pdf",
      "/__pdf-auth"
    ]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
